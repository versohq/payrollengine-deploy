# Stack identity — used in Traefik router names and in derived host
STACK_NAME=payroll-demo
STACK_HOST=payroll-demo.catapulte.studio

# Pinned versions
PE_VERSION=0.10.0-beta.4

# Secrets (generate per-instance)
MYSQL_ROOT_PASSWORD=change-me-strong
PAYROLL_API_KEY=change-me-api-key

# Regulation source — public git repo cloned on first deploy.
# Examples:
#   https://github.com/Payroll-Engine/Regulation.ES.Nomina
#   https://github.com/versohq/Regulation.FR.DirigeantSasu
REGULATION_REPO_URL=https://github.com/Payroll-Engine/Regulation.ES.Nomina

# Optional: relative path inside the repo to the entry JSON
# If empty, the first *.json found at depth <= 2 is used
REGULATION_ENTRY_FILE=

# Host port for local testing only — Dokploy exposes via Traefik
BACKEND_PORT=8080
